			local function setupCharacterESP(character)
				task.wait(0.3)
				cleanESP(character)
				
				local isStaff, staffRole = checkIsStaff(targetPlayer)
				if staffEspEnabled and not espEnabled and not isStaff then return end
				if not espEnabled and not staffEspEnabled then return end

				local head = character:WaitForChild("Head", 5)
				local root = character:WaitForChild("HumanoidRootPart", 5)
				if not head or not root then return end

				local displayName = targetPlayer.Name
				local displayRole = "Joueur"
				local boxColor = Color3.fromRGB(0, 180, 255)

				if isStaff then
					displayRole = " STAFF [" .. (staffRole or "Admin") .. "]"
					boxColor = Color3.fromRGB(128, 128, 128)
				else
					local role, rColor = detectRole(targetPlayer)
					displayRole = role
					boxColor = rColor
				end

				local hl = Instance.new("Highlight")
				hl.Name = "SF_ESP_Hl"
				hl.FillColor = boxColor
				hl.OutlineColor = boxColor
				hl.FillTransparency = 0.6
				hl.OutlineTransparency = 0.1
				hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
				hl.Parent = character

				local bgui = Instance.new("BillboardGui")
				bgui.Name = "SF_ESP_Tag"
				bgui.Size = UDim2.new(0, 200, 0, 60)
				bgui.AlwaysOnTop = true
				bgui.ExtentsOffset = Vector3.new(0, 3, 0)
				bgui.Parent = character

				local label = Instance.new("TextLabel")
				label.Size = UDim2.new(1, 0, 1, 0)
				label.BackgroundTransparency = 1
				label.Font = Enum.Font.GothamBold
				label.TextSize = 13
				label.TextColor3 = boxColor
				label.TextStrokeTransparency = 0.2
				label.TextStrokeColor3 = Color3.new(0,0,0)
				label.Parent = bgui

local connection
				connection = RunService.RenderStepped:Connect(function()
					if not character.Parent or not Player.Character then
						connection:Disconnect()
						return
					end
					-- On récupère directement les HumanoidRootPart de manière sécurisée
local myRoot = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
local targetRoot = character and character:FindFirstChild("HumanoidRootPart")
					
					if myRoot and targetRoot then
						local distance = math.floor((myRoot.Position - targetRoot.Position).Magnitude)
						label.Text = string.format(" %s\n %s\n [%d m]", displayName, displayRole, distance)
					end
				end)
			end


			if targetPlayer.Character then task.spawn(setupCharacterESP, targetPlayer.Character) end
		end
	end

