local camera = workspace.CurrentCamera
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local LocalPlayer = game:GetService("Players").LocalPlayer

local cameraRelay = Instance.new("Part")
cameraRelay.Name = "CamRelay"
cameraRelay.Transparency = 1
cameraRelay.Anchored = true
cameraRelay.CanCollide = false
cameraRelay.Size = Vector3.new(1, 1, 1)
cameraRelay.Parent = workspace

local freecamActive = false
local freecamConn = nil
local camSpeed = 1.5
local yaw, pitch = 0, 0
local targetPosition = Vector3.new(0,0,0)

local function initFreecamAngles()
    local _, y, _ = camera.CFrame:ToEulerAnglesYXZ()
    yaw = y
    pitch = 0
end

local function updateFreecam(dt)
    if not freecamActive then return end
    
    local delta = UserInputService:GetMouseDelta()
    if delta.Magnitude > 0 then
        yaw = yaw - (delta.X * 0.005)
        pitch = math.clamp(pitch - (delta.Y * 0.005), -1.5, 1.5)
    end
    local rotation = CFrame.fromEulerAnglesYXZ(pitch, yaw, 0)
    
    local move = Vector3.new(0, 0, 0)
    if UserInputService:IsKeyDown(Enum.KeyCode.W) or UserInputService:IsKeyDown(Enum.KeyCode.Z) then move = move + Vector3.new(0, 0, -1) end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then move = move + Vector3.new(0, 0, 1) end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) or UserInputService:IsKeyDown(Enum.KeyCode.Q) then move = move + Vector3.new(-1, 0, 0) end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then move = move + Vector3.new(1, 0, 0) end
    
    if move.Magnitude > 0 then
        targetPosition = targetPosition + (rotation:VectorToWorldSpace(move.Unit) * (camSpeed * 20 * dt))
    end
    
    cameraRelay.CFrame = CFrame.new(cameraRelay.CFrame.Position):Lerp(CFrame.new(targetPosition), 0.3) * rotation
    camera.CFrame = cameraRelay.CFrame
end


createPlayerToggle("Freecam", function(enabled)
    freecamActive = enabled
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    
    if enabled then
        -- Mettre à jour la référence caméra au cas où
        camera = workspace.CurrentCamera 
        initFreecamAngles()
        targetPosition = camera.CFrame.Position
        cameraRelay.CFrame = camera.CFrame
        
        camera.CameraType = Enum.CameraType.Scriptable
        camera.CameraSubject = nil
        
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.LocalTransparencyModifier = 1 end
            end
        end
        if hum then hum.PlatformStand = true end
        
        freecamConn = RunService.RenderStepped:Connect(updateFreecam)
    else
        if freecamConn then freecamConn:Disconnect(); freecamConn = nil end
        
        camera.CameraType = Enum.CameraType.Custom
        camera.CameraSubject = hum
        
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.LocalTransparencyModifier = 0 end
            end
        end
        if hum then hum.PlatformStand = false end
    end
end)



